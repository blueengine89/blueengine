{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/nonprofits",
      "destination": "/for-nonprofits",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/blog/:path*",
      "destination": "https://blog.blueenginesolutions.com/blog/:path*"
    }
  ]
}
